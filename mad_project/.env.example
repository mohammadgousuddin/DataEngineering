# MAD environment — shared by docker-compose services.
# Override per-deployment as needed.

# MQTT broker
MQTT_HOST=mosquitto
MQTT_PORT=1885

# InfluxDB 2.7
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=my-token
INFLUX_ORG=mad
INFLUX_BUCKET=greenhouse

# Random Forest model bundle (inside containers)
MODEL_PATH=/model/rf_control.pkl

# CSV telemetry log (inside containers)
CSV_PATH=/data/greenhouse.csv

# Control service inference endpoint
CONTROL_URL=http://control:8000

# Host serial port for sensor_bridge.py (host-side only)
SERIAL_PORT=/dev/ttyACM0
